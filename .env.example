# AUHMC 2026 — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Secret (مفتاح سري للتشفير)
# غيّر هذا المفتاح إلى قيمة عشوائية قوية
JWT_SECRET=auhmc2026_super_secret_key_change_this_to_something_secure

# Admin Credentials (بيانات المدير)
ADMIN_EMAIL=admin@auhmc2026.sy
ADMIN_PASSWORD=admin2026

# Upload Directory (مجلد الرفع)
UPLOAD_DIR=./public/uploads

# Database (قاعدة البيانات)
# SQLite لا يحتاج إلى إعداد إضافي
DB_PATH=./data/auhmc.db

# CORS (إذا كنت تريد تقييد الوصول)
# CORS_ORIGIN=https://muqimeen.com